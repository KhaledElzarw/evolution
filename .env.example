# Binance/testnet configuration
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_MARKETDATA_URL=https://api.binance.com
# Keep Binance credentials blank in .env.example. Real secrets belong only in a local .env file or deployment secret store.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SYMBOL=BTCUSDT

# Telegram control bot configuration
TELEGRAM_CONTROL_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=

# Persistence/runtime storage
# In production, point TRADEBOT_DB_PATH to a local runtime path that is not committed.
TRADEBOT_DB_PATH=tradebot.sqlite3
TRADEBOT_BOT_KEY=tradebot-grid-paper
TRADEBOT_BOT_NAME=Tradebot Grid Paper
# Keep the engine loop fast while reducing log spam. Set 0 to disable heartbeat logs.
TRADEBOT_ENGINE_HEARTBEAT_LOG_SECONDS=60

# Dashboard configuration
# 0.0.0.0 exposes the dashboard to the network. Use localhost-only binding unless remote access is intentional.
TRADEBOT_DASHBOARD_HOST=0.0.0.0
TRADEBOT_DASHBOARD_PORT=8844
# Set TRADEBOT_DASHBOARD_TOKEN if the dashboard is not localhost-only.
TRADEBOT_DASHBOARD_TOKEN=

# Deprecated/legacy Baserow configuration
# Baserow variables are deprecated/legacy unless explicitly enabled. Legacy scripts are manual-export only.
BASEROW_URL=http://127.0.0.1:8080
BASEROW_TOKEN=
TRADEBOT_BASEROW_SYNC=0

# Local AI sidecar configuration
TRADEBOT_AI_BASE_URL=http://127.0.0.1:11434/v1
TRADEBOT_AI_PROVIDER=ollama
TRADEBOT_AI_MODEL=qwen3.5:9b
